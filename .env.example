VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Google Drive integration — Client ID is public, safe to commit.
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Netlify Functions only (set in Netlify dashboard, never commit secrets):
#   GOOGLE_CLIENT_ID         (same as VITE_GOOGLE_CLIENT_ID)
#   GOOGLE_CLIENT_SECRET     (the GOCSPX-... secret)
#   SUPABASE_URL             (same as VITE_SUPABASE_URL)
#   SUPABASE_ANON_KEY        (same as VITE_SUPABASE_ANON_KEY)
#   SUPABASE_SERVICE_ROLE_KEY (from Supabase dashboard → Settings → API)
